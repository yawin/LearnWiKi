# Environment variables (keep .env.example, ignore actual .env)
.env
.env.*
!.env.example

# Claude Code local settings (contains user-specific paths)
.claude/settings.local.json

# Local cargo config (contains absolute paths — e.g. target-dir override
# to keep build artifacts outside iCloud-synced Documents)
src-tauri/.cargo/

# Bundled yt-dlp binary — downloaded automatically by build.rs from GitHub
# releases on first build. Not committed (36MB binary).
src-tauri/resources/yt-dlp_macos

# Bundled MarkItDown converter — generated on release/build machines.
# It is packaged into the app when present, but not committed to Git.
src-tauri/resources/markitdown/bin/
src-tauri/resources/markitdown/venv/
src-tauri/resources/markitdown/VERSION.txt

# Internal planning docs (not for public repo)
docs/superpowers/
