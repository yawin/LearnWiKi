{
  "name": "learnwiki",
  "private": false,
  "version": "0.0.1",
  "description": "Desktop AI knowledge management tool for macOS and Windows — capture clipboard, build personal wiki, get AI insights",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kdsz001/LearnWiki.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:proto": "VITE_PROTOTYPE=true vite build --outDir dist-prototype",
    "preview:proto": "vite preview --outDir dist-prototype --port 4173",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "vitest run",
    "test:frontend:watch": "vitest",
    "test:backend": "cd src-tauri && $HOME/.cargo/bin/cargo test --lib matching 2>&1 && $HOME/.cargo/bin/cargo test --test integration_tests 2>&1",
    "test:backend:all": "cd src-tauri && $HOME/.cargo/bin/cargo test 2>&1",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm test && npm run test:e2e"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@types/d3-force": "^3.0.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "d3-force": "^3.0.0",
    "framer-motion": "^11",
    "i18next": "^26.0.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-force-graph-2d": "^1.29.1",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7",
    "remark-gfm": "^4.0.1",
    "zustand": "^5"
  },
  "overrides": {
    "enhanced-resolve": "5.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "tailwindcss": "^4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.4.1",
    "vitest": "^4.1.8"
  }
}
